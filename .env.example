# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=securepassword123
POSTGRES_DB=inventory_db

# Backend — constructed from above values (hostname = docker service name "db")
DATABASE_URL=postgresql://admin:securepassword123@db:5432/inventory_db

# Frontend — URL of the backend API (change to deployed backend URL for production)
VITE_API_URL=http://localhost:8000
